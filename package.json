{
  "name": "ai-proptech-challenge-project",
  "version": "0.1.0",
  "private": true,
  "description": "Abu Dhabi AI PropTech Challenge project — built from the official project template",
  "scripts": {
    "predev": "node scripts/anam-setup.mjs",
    "dev": "concurrently -n web,agent -c blue,green \"next dev\" \"npm run agent\"",
    "dev:web": "next dev",
    "agent": "python3 -m uvicorn code_agent.server:app --port 8000",
    "setup:anam": "node scripts/anam-setup.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@anam-ai/js-sdk": "^4.17.1",
    "framer-motion": "^12.42.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.38",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0"
  }
}
