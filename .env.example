# Copy to .env.local and fill in only what you use.
# The template runs with NO keys by default (mock engine).
#
# Security note: variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# Keep real API keys un-prefixed and call providers from a route handler
# (app/api/run/route.ts) so keys stay server-side.

# Anam.ai — real-time avatar (server-side only, never NEXT_PUBLIC_)
# Used by scripts/anam-setup.mjs and app/api/anam/session/route.ts
ANAM_API_KEY=

# OpenAI — used by code_agent.py (the data-analysis tool behind Hakim AI)
OPENAI_API_KEY=

# Optional: point code_agent at a different OpenAI-compatible provider (e.g. Fireworks)
# LLM_API_KEY=
# LLM_BASE_URL=https://api.fireworks.ai/inference/v1
# LLM_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# Python sidecar that runs code_agent (started by `npm run agent`)
AGENT_URL=http://localhost:8000

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Hugging Face Inference
HF_TOKEN=

# Local model endpoint (e.g. Ollama)
LOCAL_MODEL_URL=http://localhost:11434

# Your own API
CUSTOM_API_URL=
CUSTOM_API_KEY=
